---
import BaseHead from '../components/BaseHead.astro';
import Button from '../components/Button.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Section from '../components/Section.astro';
import { SITE_TITLE } from '../consts';

const features = [
	{
		title: 'Immutable',
body: 'Inspired by Bluefin, Sivablue is built on bootc and is immutable... System files are not editable.',
	},
	{
		title: 'Automatic Updates',
body: 'Automatic updates on reboot and a daily update cadence ensures you\'re never outdated.',
	},
	{
		title: 'Tools (mostly) ready to go',
body: 'All the basic tools you want for pentesting are easily installed via provided instructions.',
	},
	{
		title: 'Containerised Workloads',
body: 'Easy access to containerised environments with Docker, Podman, Distrobox, and Ptyxis terminal by default.',
	},
	{
		title: 'No package? No problem!',
body: 'Brew and Flatpak come configured out-of-the-box to install any CLI tools and GUI apps supported on Linux.',
	},
	{
		title: 'Out-of-the-Box Driver Installation',
body: 'Nvidia flavours come with drivers out-of-the-box. No more hassle installing them.',
	},
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Sivablue — ${SITE_TITLE}`} description="A project by Luke Chapman." />
	</head>
	<body>
		<Header />
		<main>
			<!-- Hero -->
			<section class="relative overflow-hidden">
				<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-deep-900 via-deep-800 to-sivablue-900"></div>
				<div class="pointer-events-none absolute inset-0 opacity-70 [background:radial-gradient(800px_400px_at_80%_-10%,rgba(34,211,238,0.35),transparent_60%),radial-gradient(600px_400px_at_-10%_20%,rgba(124,58,237,0.25),transparent_60%)]"></div>

				<Section width="wide" class="relative py-28 text-white sm:py-36">
					<p class="text-xs font-bold uppercase tracking-[0.22em] text-sivablue-200">Project</p>
					<h1 class="font-display mt-4 text-5xl font-semibold leading-[1.02] tracking-tight text-white sm:text-7xl">
						Siva<span class="text-sivablue-300" style="text-shadow: 0 0 40px rgba(34,211,238,0.7);">blue</span>.
					</h1>
					<p class="mt-6 max-w-xl text-lg leading-relaxed text-white/80">
                        The stable, ready to go pentesting operating system you would actually daily drive
					</p>
					<div class="mt-10 flex flex-wrap gap-3">
						<Button href="#learn-more" variant="primary">
							Learn more
							<span aria-hidden="true">→</span>
						</Button>
						<Button href="/" variant="ghost" class="!border-white/20 !bg-white/10 !text-white hover:!text-white">
							Back to home
						</Button>
					</div>
				</Section>
			</section>

			<!-- Features -->
			<Section width="wide" class="py-24" as="section">
				<div id="learn-more" class="mb-12">
					<p class="eyebrow mb-3">The Mission</p>
					<h2 class="font-display max-w-2xl text-3xl font-semibold leading-tight sm:text-4xl">
                        Create a Pentesting OS which you can daily drive, spin up, and configure in less than an hour without faffing with Nvidia Drivers.
					</h2>
				</div>
				<div class="grid gap-6 md:grid-cols-3">
					{features.map((f, i) => (
						<div class="glass rounded-2xl p-6">
							<div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--accent-soft)] font-display text-lg font-semibold text-[var(--accent)]">
								{String(i + 1).padStart(2, '0')}
							</div>
							<h3 class="font-display text-xl font-semibold text-[var(--text)]">{f.title}</h3>
							<p class="mt-2 text-[var(--text-muted)] leading-relaxed">{f.body}</p>
						</div>
					))}
				</div>
			</Section>

			<!-- Prose block -->
			<Section width="narrow" class="py-16">
				<div class="prose">
					<h2>The Story</h2>
                        <blockquote>
					    <p>
                            "That is SIVA. With the proper direction, it could create anything a civilisation would need... At least in theory."
                        </p>
                        <cite>
                            <a href="https://www.destinypedia.com/Lord_Saladin" target="_blank">Lord Saladin, Destiny: The Rise of Iron</a>
                        </cite>
                    </blockquote>
                    <p>
                        Sivablue is my aim to give a proper direction for Pentesting operating systems. For too long, running Kali in a VM has been the method many default to. I find this clunky, awkward, sluggish, and annoying to work out of. Sivablue aims to be easy to install, setup, maintain, and provide a stable daily driver WITHOUT dependency nightmares.
                    </p>
					<p>
                        I've always had an issue with installing Nvidia drivers with Linux, and I've also had issues when package dependency issues break my system.
I also don't like the idea of running things like Kali in a VM... what if I could have all my tools with the performance of a local machine, have access to a VMs, and just have a system with all the tools I need as a pentester just ready to go?
					</p>
                    <p>
                        Inspired by Bluefin and Universal Blue, I built Sivablue to have all the tools I'd want as a pentester, ready to go, out the gate, while also being as stable as possible. Nvidia flavours come with all drivers installed, and are easily integrated into Podman/Docker workloads.
                    </p>
                    <p>
                        This is just the beginning. I am already working on a more comprehensive version which utilises a fieldkit for all tools, so any pentesting tools you can think of will be ready to go, immediately on first boot. A headless verison that be used as an internal network VM is also in the works so watch this space!
                    </p>
				</div>
			</Section>

			<!-- For Pentesters -->
			<section class="relative overflow-hidden">
				<div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-deep-900 via-deep-800 to-sivablue-900"></div>
				<div class="pointer-events-none absolute inset-0 opacity-60 [background:radial-gradient(700px_400px_at_90%_20%,rgba(34,211,238,0.25),transparent_60%),radial-gradient(500px_400px_at_0%_80%,rgba(124,58,237,0.2),transparent_60%)]"></div>

				<Section width="wide" class="relative py-24 text-white sm:py-28">
					<p class="text-xs font-bold uppercase tracking-[0.22em] text-sivablue-200">For</p>
					<h2 class="font-display mt-2 text-5xl font-bold uppercase leading-[0.95] tracking-tight text-white sm:text-7xl">
						Pentesters
					</h2>

					<p class="mt-8 max-w-2xl text-base leading-relaxed text-white/80 sm:text-lg pb-4">
                        Sivablue offers a number of tools to help you start pentesting as quickly as possible, and quality of life tools.
					</p>

					<div class="mx-auto grid max-w-4xl gap-x-12 gap-y-10 sm:grid-cols-2">
						{[
                            { title: 'Podman & Docker', body: 'Podman and Docker support to install anything as a Container.', icon: '/Podman.svg' },
                            { title: 'Kali & Metasploit', body: 'Pullable and Aliased via ujust command runners.', icon: '/kali-linux.svg' },
                            { title: 'Distrobox', body: 'Install, test, and experiment in sandboxed container environments. Supports dozens of Linux flavours', icon: '/Distrobox-logomark.svg' },
                            { title: 'VSCode', body: 'VSCode with removed telemetry, and a number of extensions preconfigured.', icon: '/vscode.svg' },
                            { title: 'Linuxbrew', body: 'CLI tools from the Mac ecosystem - separated from your system binaries.', icon: '/homebrew.svg' },
                            { title: 'QEMU/KVM VMs', body: 'Libvirtd for any VMs desired, including Windows 11.', icon: '/qemu.svg' },
						].map((item) => (
							<div class="border-t border-white/10 pt-6">
								<div class="mb-4 inline-flex h-16 w-16 items-center justify-center rounded-lg bg-white/5 p-1.5 ring-1 ring-inset ring-white/10">
									<img src={item.icon} alt="" width="40" height="40" class="h-full w-full object-contain" />
								</div>
								<h3 class="font-display text-lg font-semibold text-white">{item.title}</h3>
								<p class="mt-2 text-sm leading-relaxed text-white/70">{item.body}</p>
							</div>
						))}
					</div>
				</Section>
			</section>

			<!-- Footer CTA -->
			<Section width="default" class="pt-20 pb-24">
				<div class="glass rounded-2xl p-10 text-center">
					<h2 class="font-display text-3xl font-semibold sm:text-4xl">Documentation Coming Soon...</h2>
                    <h3 class="font-display text-4xl font-semibold sm:text-2xl">For now, Message me on Linkedin!</h3>
					<div class="mt-6 flex justify-center gap-3">
                        <Button href="https://github.com/Sir-Mudkip/Sivablue" variant="ghost">Source Code</Button>
						<Button href="/about" variant="primary">About me</Button>
						<Button href="/blog" variant="ghost">Read the blog</Button>
					</div>
				</div>
			</Section>
		</main>
		<Footer />
	</body>
</html>
