---
interface Props {
	class?: string;
	width?: 'narrow' | 'default' | 'wide';
	as?: string;
}

const { class: className = '', width = 'default', as: Tag = 'section' } = Astro.props;

const widths = {
	narrow: 'max-w-2xl',
	default: 'max-w-5xl',
	wide: 'max-w-6xl',
};
---

<Tag class={`mx-auto w-full px-5 sm:px-8 ${widths[width]} ${className}`}>
	<slot />
</Tag>
