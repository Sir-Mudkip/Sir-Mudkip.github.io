---
import { SITE_TITLE, AUTHOR_NAME, SOCIALS, NAV_LINKS } from '../consts';

const year = new Date().getFullYear();
---

<footer class="relative mt-24 border-t border-[var(--border)] pt-16 pb-10">
	<div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sivablue-400/50 to-transparent"></div>

	<div class="mx-auto grid max-w-6xl gap-10 px-5 sm:px-8 md:grid-cols-[1.4fr_1fr_1fr]">
		<div>
			<h3 class="font-display text-2xl font-semibold text-[var(--text)]">{SITE_TITLE}</h3>
			<p class="mt-3 max-w-sm text-sm leading-relaxed text-[var(--text-muted)]">
                A small corner of the internet for notes, project logs, rabbit holes, and other tech ramblings.
			</p>
		</div>

		<div>
			<p class="eyebrow mb-3">Navigation</p>
			<ul class="space-y-2 text-sm">
				{NAV_LINKS.map((link) => (
					<li>
						<a class="text-[var(--text-muted)] no-underline hover:text-[var(--accent)]" href={link.href}>{link.label}</a>
					</li>
				))}
			</ul>
		</div>

		<div>
			<p class="eyebrow mb-3">Find me</p>
			<ul class="space-y-2 text-sm">
				{SOCIALS.length === 0 && (
					<li class="text-[var(--text-muted)]">Links coming soon.</li>
				)}
				{SOCIALS.map((s) => (
					<li>
						<a class="text-[var(--text-muted)] no-underline hover:text-[var(--accent)]" href={s.href} target="_blank" rel="noopener noreferrer">{s.label}</a>
					</li>
				))}
			</ul>
		</div>
	</div>

	<div class="mx-auto mt-12 flex max-w-6xl items-center justify-between gap-4 px-5 text-xs text-[var(--text-muted)] sm:px-8">
		<span>&copy; {year} {AUTHOR_NAME}</span>
	</div>
</footer>
