---
import { SITE_TITLE, NAV_LINKS, SOCIALS } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="sticky top-0 z-40 border-b border-[var(--border)] backdrop-blur-xl bg-[color-mix(in_srgb,var(--surface)_72%,transparent)]">
	<nav class="mx-auto flex max-w-6xl items-center justify-between gap-6 px-5 py-4 sm:px-8">
		<a href="/" class="group flex items-baseline gap-2 text-[var(--text)] no-underline hover:text-[var(--text)]">
			<span class="font-display text-xl font-semibold tracking-tight">{SITE_TITLE}</span>
			<span class="hidden h-1.5 w-1.5 rounded-full bg-sivablue-400 shadow-[0_0_12px_var(--accent)] sm:inline-block"></span>
		</a>

		<div class="hidden items-center gap-7 md:flex">
			{NAV_LINKS.map((link) => (
				<HeaderLink href={link.href}>{link.label}</HeaderLink>
			))}
		</div>

		<div class="flex items-center gap-2">
			{SOCIALS.map((s) => (
				<a
					href={s.href}
					target="_blank"
					rel="noopener noreferrer"
					class="hidden h-9 w-9 items-center justify-center rounded-full border border-transparent text-[var(--text-muted)] transition hover:border-[var(--border)] hover:text-[var(--accent)] sm:inline-flex"
				>
					<span class="sr-only">{s.label}</span>
					{s.key === 'github' && (
						<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18">
							<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
						</svg>
					)}
					{s.key === 'linkedin' && (
						<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18">
							<path fill="currentColor" d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.62 0 4.29 2.38 4.29 5.48v6.26zM5.34 7.43a2.07 2.07 0 1 1 0-4.13 2.07 2.07 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/>
						</svg>
					)}
					{s.key === 'email' && (
						<svg viewBox="0 0 24 24" aria-hidden="true" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<rect x="3" y="5" width="18" height="14" rx="2"></rect>
							<path d="m3 7 9 6 9-6"></path>
						</svg>
					)}
				</a>
			))}
			<ThemeToggle />

			<details class="relative md:hidden">
				<summary class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full border border-[var(--border)] bg-[var(--surface-2)] [&::-webkit-details-marker]:hidden">
					<span class="sr-only">Menu</span>
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
						<path d="M3 6h18M3 12h18M3 18h18"></path>
					</svg>
				</summary>
				<div class="glass absolute right-0 top-12 flex min-w-[180px] flex-col gap-1 rounded-xl p-3 shadow-lg">
					{NAV_LINKS.map((link) => (
						<a href={link.href} class="rounded-md px-3 py-2 text-sm text-[var(--text)] hover:bg-[var(--accent-soft)]">{link.label}</a>
					))}
				</div>
			</details>
		</div>
	</nav>
</header>
